# macOS
.DS_Store

# Obsidian — конфиг приложения и кэши воркспейса не коммитим
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json
.trash/

# Временные/черновики
.context/
*.tmp

# Obsidian служебное (пустые холсты, в т.ч. русская локаль)
Untitled.canvas
Без названия.canvas

# Claude Code — локальные настройки/разрешения (машинно-зависимые)
.claude/settings.local.json

# Тяжёлые/бинарные источники raw/ — версионируем вику, а не сырьё (книги/видео/скрины живут локально)
raw/**/*.pdf
raw/**/*.epub
raw/**/*.doc
raw/**/*.docx
raw/**/*.fb2
raw/**/*.rtf
raw/**/*.png
raw/**/*.jpg
raw/**/*.jpeg
raw/**/*.webp
raw/**/*.gif
raw/**/*.heic
raw/**/*.tiff
raw/**/*.bmp
raw/**/*.mp4
raw/**/*.mov
raw/**/*.m4v
raw/**/*.webm
raw/**/*.mkv
raw/**/*.mp3
raw/**/*.m4a
raw/**/*.wav

# Данные от агента-коуча (health/психика) — приватны, живут локально в .context/ (уже игнорится выше),
# в git-историю этого репо не попадают. Граница приватности: контент отсюда не реплицируем в health-репо.
